knitr::opts_chunk$set(collapse = TRUE, comment = "#>")
library(NeStage)
A_obs <- matrix(0, 3, 3)
A_obs[1, 3] <- 0.9
A_obs[1, 1] <- 0.10; A_obs[2, 2] <- 0.20; A_obs[3, 3] <- 0.60
A_obs[2, 1] <- 0.35; A_obs[3, 2] <- 0.25
A_obs[1, 2] <- 0.05; A_obs[2, 3] <- 0.10
A_exp <- matrix(0, 3, 3)
A_exp[1, 3] <- 1.0
A_exp[1, 1] <- 0.12; A_exp[2, 2] <- 0.22; A_exp[3, 3] <- 0.58
A_exp[2, 1] <- 0.30; A_exp[3, 2] <- 0.28
A_exp[1, 2] <- 0.06; A_exp[2, 3] <- 0.09
# Inspect
dim(A_obs); dim(A_exp)
A_obs
A_exp
res <- nestage_run_all(
A_obs = A_obs,
A_exp = A_exp,
repro_stage = 3,
frac_repro = 0.10,
meta = list(population = "Yonezawa-demo")
)
res
nestage_compare(res)
nestage_plot_ratios_gg(res)           # ggplot2 version
nestage_plot_gg(res)           # ggplot2 version
nestage_plots_gg(res)           # ggplot2 version
## ---- rename-and-plot, message=FALSE, warning=FALSE ----
# If you are using the demo "Yonezawa-demo" row from the vignette,
# decide which paper label you want to show for that row:
#   Option A: show it as "Miz"
#   Option B: show it as "Nan"
# Pick ONE of these maps:
# --- Option A (map demo to "Miz") ---
pop_map <- c("Yonezawa-demo" = "Miz", "Miz" = "Miz", "Nan" = "Nan")
# --- Option B (map demo to "Nan") ---
# pop_map <- c("Yonezawa-demo" = "Nan", "Miz" = "Miz", "Nan" = "Nan")
# Apply the mapping (base R, no extra deps)
idx <- match(res$population, names(pop_map))
res_named <- res
res_named$population <- ifelse(is.na(idx), res$population, unname(pop_map[idx]))
# Order factor levels exactly as in the paper
res_named$population <- factor(res_named$population, levels = c("Miz","Nan"))
# ========== PLOT with ggplot2 ==========
if (!requireNamespace("ggplot2", quietly = TRUE)) install.packages("ggplot2")
library(ggplot2)
# ---- Ny/N and Ne/N facet plot (inline ggplot; works even if you didn’t add package plotters) ----
dd <- rbind(
data.frame(population = res_named$population, model = res_named$model,
metric = "Ny/N", value = res_named$NyN, stringsAsFactors = FALSE),
data.frame(population = res_named$population, model = res_named$model,
metric = "Ne/N", value = res_named$NeN, stringsAsFactors = FALSE)
)
dd <- dd[is.finite(dd$value), , drop = FALSE]
if (nrow(dd) == 0L) {
stop("No finite Ny/N or Ne/N to plot. Paste your v0.6.0 estimators into NeStage so NyN/NeN are numeric.")
}
str(res)
