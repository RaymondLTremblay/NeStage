devtools::document()
devtools::document()
devtools::install()
devtools::check()
# from package root
unlink("man/nestage_sex_only.Rd")  # remove the broken file
devtools::document()
devtools::check()
unlink("man/nestage_sex_only.Rd")
devtools::document()
tools::showNonASCIIfile("R/nestage-plots.R")
devtools::document()
# Append to .Rbuildignore (create if missing)
lines <- c("^.*\\.Rproj$", "^\\.Rproj\\.user$", "^LICENSE\\.md$")
write(lines, ".Rbuildignore", sep = "\n", append = file.exists(".Rbuildignore"))
# Paths R will use
user_path <- path.expand("~/.Renviron")
project_path <- file.path(getwd(), ".Renviron")
system_path <- file.path(R.home("etc"), "Renviron.site")
cat("User .Renviron:   ", user_path, "exists:", file.exists(user_path), "\n")
cat("Project .Renviron: ", project_path, "exists:", file.exists(project_path), "\n")
cat("System Renviron.site:", system_path, "exists:", file.exists(system_path), "\n")
# Back it up first (just in case)
file.copy("~/.Renviron", "~/.Renviron.bak", overwrite = TRUE)
# Open it for editing
usethis::edit_r_environ(scope = "user")
