# Step 3 — Compute $\lambda$, stable stage distribution, and generation time $L$

```{r eigen-and-L, message=FALSE, warning=FALSE}
A_Miz <- A_from_TF(T_Miz, F_Miz)
A_Nan <- A_from_TF(T_Nan, F_Nan)

eg_Miz <- eigs_popbio(A_Miz)
eg_Nan <- eigs_popbio(A_Nan)

# Generation time: native Yonezawa formula (x = 1..500; paper p. 2008-2009)
L_Miz_Y <- gen_time_yonezawa(T_Miz, F_Miz, xmax = 500)
L_Nan_Y <- gen_time_yonezawa(T_Nan, F_Nan, xmax = 500)

# Generation time: popbio / Caswell method (for comparison only)
L_Miz_P <- gen_time_popbio(A_Miz)
L_Nan_P <- gen_time_popbio(A_Nan)

# Use Yonezawa L for all subsequent calculations
L_Miz <- L_Miz_Y
L_Nan <- L_Nan_Y

knitr::kable(
  data.frame(
    Population = c("Miz", "Nan"),
    lambda     = round(c(eg_Miz$lambda, eg_Nan$lambda), 4),
    L_Yonezawa = round(c(L_Miz_Y, L_Nan_Y), 3),
    L_popbio   = round(c(L_Miz_P, L_Nan_P), 3),
    L_paper    = c(13.399, 8.353),
    check.names = FALSE
  ),
  caption = paste("Eigenvalues and generation times.",
                  "L_Yonezawa uses the native age-by-stage iteration (x = 1..500)",
                  "as defined in the paper;",
                  "L_popbio uses the Caswell sensitivity method;",
                  "L_paper is the value reported in Table 4 of Yonezawa et al. (2000).")
)
```

> Both methods produce $L$ values that closely match the paper. `L_Yonezawa`
> implements the formula exactly as defined in the paper and is used for all
> subsequent calculations.

