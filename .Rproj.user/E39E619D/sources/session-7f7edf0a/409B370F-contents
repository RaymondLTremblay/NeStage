# Step 7 — NeStage package API

Once installed, the `NeStage` package exposes the same pipeline through a clean API.
The shim below transparently falls back to the vignette implementations until the
package is available.

```{r nestage-shim, message=FALSE, warning=FALSE}
has_NeStage <- requireNamespace("NeStage", quietly = TRUE) &&
  all(c("Ne_general", "generation_time_yonezawa",
        "assemble_A", "u_bar") %in% getNamespaceExports("NeStage"))

if (has_NeStage) {
  message("NeStage package found — using package functions.")
  nestage_assemble_A <- NeStage::assemble_A
  nestage_gen_time   <- NeStage::generation_time_yonezawa
  nestage_ubar       <- NeStage::u_bar
  nestage_Ne_general <- NeStage::Ne_general
} else {
  message("NeStage not yet installed — using vignette implementations as shim.")
  nestage_assemble_A <- A_from_TF
  nestage_gen_time   <- function(T_mat, F_mat) gen_time_yonezawa(T_mat, F_mat)
  nestage_ubar       <- u_bar_from_T
  nestage_Ne_general <- compute_Ne_general
}

A_Miz_ns  <- nestage_assemble_A(T_Miz, F_Miz)
A_Nan_ns  <- nestage_assemble_A(T_Nan, F_Nan)
L_Miz_ns  <- nestage_gen_time(T_Miz, F_Miz)
L_Nan_ns  <- nestage_gen_time(T_Nan, F_Nan)
res_Miz_ns <- nestage_Ne_general(T_Miz, F_Miz, D_obs_Miz, L = L_Miz_ns)
res_Nan_ns <- nestage_Ne_general(T_Nan, F_Nan, D_obs_Nan, L = L_Nan_ns)

knitr::kable(
  data.frame(
    Population = c("Miz", "Nan"),
    L          = round(c(L_Miz_ns, L_Nan_ns), 3),
    "Ne/N"     = round(c(res_Miz_ns$NeN, res_Nan_ns$NeN), 3),
    "Paper Ne/N" = c(0.219, 0.291),
    check.names = FALSE
  ),
  caption = "NeStage API output: L and Ne/N should match Table 4 of the paper."
)
```

