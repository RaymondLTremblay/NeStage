# Step 1 — Load packages and define helper functions

```{r helpers-popbio, message=FALSE, warning=FALSE}
if (!requireNamespace("popbio",  quietly = TRUE)) install.packages("popbio")
if (!requireNamespace("popdemo", quietly = TRUE)) install.packages("popdemo")
if (!requireNamespace("gt",      quietly = TRUE)) install.packages("gt")
library(popbio)
library(popdemo)
library(gt)

# -----------------------------------------------------------------------
# Helper 1: Assemble projection matrix A = T + F
# -----------------------------------------------------------------------
A_from_TF <- function(T_mat, F_mat) {
  stopifnot(all(dim(T_mat) == dim(F_mat)), nrow(T_mat) == ncol(T_mat))
  T_mat + F_mat
}

# -----------------------------------------------------------------------
# Helper 2: Eigen analysis via popbio (lambda, stable stage w, repro value v)
# -----------------------------------------------------------------------
eigs_popbio <- function(A) {
  ea <- popbio::eigen.analysis(A)
  w  <- as.numeric(ea$stable.stage); w <- w / sum(w)
  v  <- as.numeric(ea$repro.value);  v <- v / sum(v * w)
  list(lambda = as.numeric(ea$lambda1), w = w, v = v)
}

# -----------------------------------------------------------------------
# Helper 3a: Generation time — Yonezawa (2000) definition
#   L = sum(x * m_x * l_x) / sum(m_x * l_x),  x = 1 .. xmax
#   Cohort is averaged over all source stages i, weighted by the
#   stable stage distribution w (derived from A = T + F).
#   u_{j|x,i} = element (j,i) of T^x (left-multiply: T_mat %*% T^(x-1))
#   l_x = sum_i w_i * sum_j u_{j|x,i}
#   m_x = sum_i w_i * sum_j F_j * u_{j|x,i}
# -----------------------------------------------------------------------
gen_time_yonezawa <- function(T_mat, F_mat, xmax = 500) {
  s    <- nrow(T_mat)
  Fvec <- as.numeric(F_mat[1, ])     # fecundity of each stage (row 1 of F)
  A    <- T_mat + F_mat
  ev   <- eigen(A)
  w    <- Re(ev$vectors[, 1])
  w    <- abs(w) / sum(abs(w))       # stable stage distribution

  Tx  <- diag(s)                     # T^0 = I
  num <- 0; den <- 0
  for (x in seq_len(xmax)) {
    Tx  <- T_mat %*% Tx              # T^x via left-multiply
    l_x <- 0; m_x <- 0
    for (i in seq_len(s)) {
      u_jxi <- Tx[, i]               # stage distribution at age x from source i
      l_x   <- l_x + w[i] * sum(u_jxi)
      m_x   <- m_x + w[i] * sum(Fvec * u_jxi)
    }
    num <- num + x * m_x * l_x
    den <- den + m_x * l_x
  }
  if (den == 0) stop("Generation time undefined: no reproductive output over xmax years.")
  num / den
}

# -----------------------------------------------------------------------
# Helper 3b: Generation time — Caswell / popbio method (for comparison)
# -----------------------------------------------------------------------
gen_time_popbio <- function(A) as.numeric(popbio::generation.time(A))

# -----------------------------------------------------------------------
# Helper 4: Stage-weighted mean of squared survivals (Yonezawa Table 4 formula)
#   u_bar = sum_i D_i * u_{.i},  u_{.i} = colSums(T)
# -----------------------------------------------------------------------
over_u2_from_T <- function(T_mat, D) { u <- colSums(T_mat); sum(D * u^2) }

# -----------------------------------------------------------------------
# Helper 5: Clonal-dominant formulas (Eq. 10 and Eq. 11)
# -----------------------------------------------------------------------
Ny_over_N        <- function(over_u2)       1 / (1 - over_u2)
Ne_over_N_approx <- function(over_u2, L) 1 / ((1 - over_u2) * L)
Min_N_for_Ne     <- function(NeN_val, Ne_target = 5000) Ne_target / NeN_val
```

