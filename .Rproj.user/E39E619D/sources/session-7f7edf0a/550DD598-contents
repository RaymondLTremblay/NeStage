# Step 6 — General Yonezawa variance formula (full model)

The clonal-dominant Eq. 10 and Eq. 11 are **special cases** of the general model (Eq. 6).
The `NeStage` package implements the general model, which handles:

- Mixed sexual and clonal reproduction with any $d_i$
- Non-Poisson reproductive variance (any $(V_k/\bar{k})_i$ and $(V_c/\bar{c})_i$)
- Inbreeding or assortative mating via $a \neq 0$
- Any number of stages $s$

## The `compute_Ne_general` function

```{r general-Ne-function, message=FALSE, warning=FALSE}
# -----------------------------------------------------------------------
# compute_Ne_general()
#
# Implements the full Yonezawa (2000) general model (Eq. 5 and Eq. 6):
#
#   S_i = (1 - a) + (1 + a) * (Vk/k_bar)_i           [paper p. 2008]
#   A_i = 2*(1 + a)*(Vc/c_bar)_i - S_i                [paper p. 2008]
#                                   ^--- subtract S_i once (not 2*S_i)
#
#   V   = 2(1+a)(overline_u2 - u_bar^2)
#         + (1 - u_bar) * [Avr(S) + Avr(Ad)]           [Eq. 6]
#
#   Ne  = 2N / (V * L)                                 [Eq. 6]
#   Ne/N = 2  / (V * L)                                (independent of N)
#
# NULL defaults reproduce the clonal-dominant Poisson special case
# (d = 1, Vk_over_k = 1, Vc_over_c = 1, a = 0) which gives Eq. 10.
# -----------------------------------------------------------------------
compute_Ne_general <- function(T_mat,
                               F_mat,
                               D,
                               Vk_over_k = NULL,
                               Vc_over_c = NULL,
                               d         = NULL,
                               a         = 0,
                               L,
                               p         = 0.5,
                               N         = 1) {
  s <- length(D)
  stopifnot(nrow(T_mat) == s, ncol(T_mat) == s, length(D) == s)

  if (is.null(d))         d         <- rep(1, s)
  if (is.null(Vk_over_k)) Vk_over_k <- rep(1, s)
  if (is.null(Vc_over_c)) Vc_over_c <- rep(1, s)

  pq      <- p * (1 - p)
  u_dot   <- colSums(T_mat)
  u_bar   <- sum(D * u_dot)
  over_u2 <- sum(D * u_dot^2)

  S_i <- (1 - a) + (1 + a) * Vk_over_k
  A_i <- 2 * (1 + a) * Vc_over_c - S_i   # paper p. 2008: subtract S_i once

  F_vec <- as.numeric(F_mat[1, ])
  r_i   <- F_vec * D

  if (sum(r_i) == 0)
    stop("sum(r_i) = 0: the general formula requires some newborn recruitment.")

  Avr_S  <- sum(r_i * S_i)     / sum(r_i)
  Avr_Ad <- sum(r_i * A_i * d) / sum(r_i)

  V_full <- 2 * (1 + a) * (over_u2 - u_bar^2) +
            (1 - u_bar) * (Avr_S + Avr_Ad)

  Ne_val <- 2 * N / (V_full * L)
  NeN    <- 2     / (V_full * L)

  list(u_dot = u_dot, u_bar = u_bar, over_u2 = over_u2,
       S_i = S_i, A_i = A_i, r_i = r_i,
       Avr_S = Avr_S, Avr_Ad = Avr_Ad, V_full = V_full,
       Ne = Ne_val, NeN = NeN)
}
```

## Internal consistency check

Under clonal-dominant Poisson defaults, `compute_Ne_general` must reproduce
the same $N_e/N$ as Eq. 10. Any difference $> 10^{-10}$ indicates a coding error.

```{r general-Ne-main, message=FALSE, warning=FALSE}
res_Miz_gen <- compute_Ne_general(T_Miz, F_Miz, D_obs_Miz, L = L_Miz, a = 0)
res_Nan_gen <- compute_Ne_general(T_Nan, F_Nan, D_obs_Nan, L = L_Nan, a = 0)

data.frame(
  Population  = c("Miz", "Nan"),
  NeN_Eq10    = round(c(NeN_Miz_obs, NeN_Nan_obs), 6),
  NeN_general = round(c(res_Miz_gen$NeN, res_Nan_gen$NeN), 6),
  Difference  = formatC(c(abs(res_Miz_gen$NeN - NeN_Miz_obs),
                           abs(res_Nan_gen$NeN - NeN_Nan_obs)),
                         format = "e", digits = 2)
) |>
  gt() |>
  tab_header(
    title    = md("**Internal consistency check**"),
    subtitle = md("Ne/N from `compute_Ne_general` (general model, default args) vs Eq. 10 shortcut")
  ) |>
  cols_label(Population = "Population",
             NeN_Eq10   = md("*N*_e/*N* (Eq. 10)"),
             NeN_general = md("*N*_e/*N* (general)"),
             Difference  = "Difference") |>
  tab_footnote("Difference should be < 1e-10 when using clonal-dominant Poisson defaults.") |>
  tab_options(table.width = pct(65))
```

