# Step 3 — Compute $\lambda$, stable stage distribution, and generation time $L$

```{r eigen-and-L, message=FALSE, warning=FALSE}
A_Miz <- A_from_TF(T_Miz, F_Miz)
A_Nan <- A_from_TF(T_Nan, F_Nan)

eg_Miz <- eigs_popbio(A_Miz)
eg_Nan <- eigs_popbio(A_Nan)

# L: use values reported in Table 4 of Yonezawa et al. (2000).
# These are the authoritative values for replication.
L_Miz <- 13.399
L_Nan <-  8.353

# Exploratory: compare to two computational approximations
L_Miz_Y <- gen_time_yonezawa(T_Miz, F_Miz, xmax = 500)  # T^x iteration (approx)
L_Nan_Y <- gen_time_yonezawa(T_Nan, F_Nan, xmax = 500)
L_Miz_P <- gen_time_popbio(A_Miz)                        # Caswell sensitivity method
L_Nan_P <- gen_time_popbio(A_Nan)
```

