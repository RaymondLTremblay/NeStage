# R/nestage-utils.R

#' Rename population labels to paper names
#'
#' @param df Data frame with a 'population' column.
#' @param map A named character vector: names are current labels,
#'   values are the desired (paper) labels.
#'   Example: c("miz" = "Mizunami", "nan" = "Nansei", "Yonezawa-demo" = "Yonezawa demo")
#' @param drop_unmapped Logical; if TRUE, drop rows whose population is not in 'map'.
#' @param order_levels Logical; if TRUE, set factor levels to the order of 'map'.
#' @return A modified data.frame with renamed (and optionally ordered) 'population'.
#' @export
nestage_rename_populations <- function(df, map,
                                       drop_unmapped = FALSE,
                                       order_levels = TRUE) {
  stopifnot("population" %in% names(df))
  old <- as.character(df$population)
  matched <- match(old, names(map))
  new <- ifelse(is.na(matched), old, unname(map[matched]))
  df$population <- new

  if (drop_unmapped) {
    keep <- !is.na(matched)
    df <- df[keep, , drop = FALSE]
  }
  if (order_levels) {
    # use the order provided in 'map' for factor levels
    df$population <- factor(df$population,
                            levels = unique(unname(map)))
  }
  df
}
