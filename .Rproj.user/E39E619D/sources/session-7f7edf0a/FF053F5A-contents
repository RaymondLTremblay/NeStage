# Given a projection matrix A, return the dominant eigenvalue (lambda).
.nestage_lambda <- function(A) {
  # If you have a more stable routine, paste it here.
  Re(eigen(A)$values[1])
}

# TEMPORARY estimator just to enable plotting; replace with v0.6.0 math later
.nestage_estimate_core <- function(A, compute_L = FALSE) {
  # dominant eigen structure
  eig <- eigen(A)
  lambda <- Re(eig$values[1])

  # right eigenvector (stable stage dist), normalize to sum 1
  w <- Re(eig$vectors[, 1]); w <- w / sum(w)

  # left eigenvector (reproductive value), normalize so v^T w = 1
  v <- Re(eigen(t(A))$vectors[, 1])
  v <- v / sum(v * w)

  # crude stage-based proxies until you paste real formulas
  NyN <- sum(v * w)
  NeN <- (sum(v * w))^2 / sum((v^2) * w)

  L <- if (isTRUE(compute_L)) {
    idx <- seq_along(w)
    sum(idx * v * w) / sum(v * w)
  } else {
    NA_real_
  }

  list(NyN = as.numeric(NyN), NeN = as.numeric(NeN), L = as.numeric(L))
}

# ---- exported API ------------------------------------------------------------

#' Return the current NeStage version tag
#' @export
nestage_version <- function() {
  "v0.6.0"
}

#' Validate a projection matrix
#'
#' @param A A square numeric matrix (projection matrix).
#' @return Invisibly TRUE or stops with an informative message.
#' @export
nestage_check_matrix <- function(A) {
  stopifnot(is.matrix(A), is.numeric(A))
  d <- dim(A)
  if (length(d) != 2 || d[1] != d[2]) stop("A must be a square matrix.")
  if (any(!is.finite(A))) stop("A contains non-finite values.")
  if (any(A < 0)) warning("A contains negative entries; verify biological plausibility.")
  invisible(TRUE)
}

#' Observed (Exact) estimator: Ny/N, Ne/N, and lambda
#'
#' @param A_obs Observed projection matrix.
#' @param meta Optional list with identifiers (for example, list(population = "Miz")).
#' @return A list of class 'nestage_result' with fields: model, NyN, NeN, lambda, L, version, meta.
#' @export
nestage_exact <- function(A_obs, meta = list()) {
  nestage_check_matrix(A_obs)

  # If your pipeline does preprocessing on observed matrices, apply it here.
  A_clean <- A_obs

  est <- .nestage_estimate_core(A_clean, compute_L = FALSE)
  lambda <- .nestage_lambda(A_clean)

  out <- list(
    model   = "Exact-Observed",
    NyN     = est$NyN,
    NeN     = est$NeN,
    lambda  = lambda,
    L       = est$L,  # typically NA for exact
    version = nestage_version(),
    meta    = meta
  )
  class(out) <- c("nestage_result", class(out))
  out
}

#' Expected estimator: Ny/N, Ne/N, and lambda
#'
#' @param A_exp Expected projection matrix.
#' @param meta Optional list with identifiers.
#' @return A list of class 'nestage_result'.
#' @export
nestage_expected <- function(A_exp, meta = list()) {
  nestage_check_matrix(A_exp)

  A_clean <- A_exp

  est <- .nestage_estimate_core(A_clean, compute_L = FALSE)
  lambda <- .nestage_lambda(A_clean)

  out <- list(
    model   = "Exact-Expected",
    NyN     = est$NyN,
    NeN     = est$NeN,
    lambda  = lambda,
    L       = est$L,  # typically NA for exact
    version = nestage_version(),
    meta    = meta
  )
  class(out) <- c("nestage_result", class(out))
  out
}

