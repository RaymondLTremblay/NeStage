#' Run Observed, Expected, and Sex-only in one call
#'
#' @param A_obs Observed matrix.
#' @param A_exp Expected matrix (optional).
#' @param repro_stage Reproductive stage(s), for example, 3.
#' @param frac_repro Default 0.10.
#' @param meta Optional identifiers list.
#' @return Tidy data.frame with rows per model.
#' @export
nestage_run_all <- function(A_obs, A_exp = NULL, repro_stage, frac_repro = 0.10, meta = list()) {
  res <- list()
  res[["Exact-Observed"]] <- nestage_exact(A_obs, meta)
  if (!is.null(A_exp)) res[["Exact-Expected"]] <- nestage_expected(A_exp, meta)
  res[["Sex-only"]] <- nestage_sex_only(A_obs, repro_stage, frac_repro, meta)

  td <- do.call(rbind, lapply(res, function(x) {
    data.frame(
      population = if (!is.null(meta$population)) meta$population else NA_character_,
      model      = x$model,
      NyN        = x$NyN,
      NeN        = x$NeN,
      L          = x$L,
      lambda     = x$lambda,
      version    = x$version,
      stringsAsFactors = FALSE
    )
  }))
  rownames(td) <- NULL
  td
}

#' Compute deltas and fold changes across models
#'
#' @param df Output from nestage_run_all() or rbind of many populations.
#' @return Data.frame with comparisons per population.
#' @export
nestage_compare <- function(df) {
  by_pop <- split(df, df$population)
  out <- lapply(by_pop, function(dd) {
    eo <- dd[dd$model == "Exact-Observed", , drop = FALSE]
    so <- dd[grepl("^Sex-only", dd$model), , drop = FALSE]
    ex <- dd[dd$model == "Exact-Expected", , drop = FALSE]

    merge_pairs <- function(a, b, prefix) {
      if (nrow(a) == 1 && nrow(b) == 1) {
        data.frame(
          population = a$population,
          compare    = prefix,
          d_NyN      = b$NyN - a$NyN,
          fc_NyN     = b$NyN / a$NyN,
          d_NeN      = b$NeN - a$NeN,
          fc_NeN     = b$NeN / a$NeN,
          d_L        = b$L - a$L,
          stringsAsFactors = FALSE
        )
      } else NULL
    }

    rbind(
      merge_pairs(eo, so, "Sex-only vs Exact-Observed"),
      if (nrow(ex) == 1) merge_pairs(eo, ex, "Exact-Expected vs Exact-Observed")
    )
  })
  do.call(rbind, out)
}
